generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Importance {
  critical
  high
  normal
}

enum Sentiment {
  positive
  negative
  neutral
}

enum ActivityLevel {
  low
  medium
  high
  critical
}

enum AlertSeverity {
  critical
  high
  medium
  low
}

enum EntityType {
  person
  org
  company
  place
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Department {
  id             String         @id
  name           String
  newsCount      Int
  level          ActivityLevel
  municipalities Municipality[]
}

model Municipality {
  id            String        @id
  name          String
  departmentId  String
  department    Department    @relation(fields: [departmentId], references: [id])
  newsCount     Int
  activityLevel ActivityLevel

  @@index([departmentId])
}

model NewsArticle {
  id             String     @id
  title          String
  summary        String
  fullText       String?
  source         String
  sourceUrl      String?
  department     String
  municipality   String
  time           String
  category       String
  importance     Importance
  sentiment      Sentiment
  sentimentScore Float?
  riskScore      Float?
  viewCount      Int?
  isBreaking     Boolean    @default(false)
  aiSummary      String
  tags           String[]
  entities       Json?
  createdAt      DateTime   @default(now())
}

model NewsSource {
  id          String  @id
  name        String
  type        String
  region      String
  newsToday   Int
  uptime      Float
  latency     Int
  lastFetchAt String?
}

model AlertItem {
  id          String        @id
  title       String
  description String
  severity    AlertSeverity
  time        String
  active      Boolean       @default(true)
}

model Entity {
  id    String     @id
  name  String
  type  EntityType
  count Int
}

// Snapshot diario del modelo de estabilidad de espectro por departamento (banda VHF/UHF),
// calculado a partir de clima real de Open-Meteo. Es histórico puramente derivado —
// no telemetría de hardware — pensado para poder graficar tendencias y líneas de tiempo.
model SpectrumSnapshot {
  id              String   @id @default(cuid())
  department      String
  capturedAt      DateTime @default(now())
  tempC           Float
  humidityPct     Float
  precipitationMm Float
  stability       String
  attenuationDbKm Float
  refractivity    Float

  @@index([department, capturedAt])
}

// Boletín/briefing generado por IA a partir de datos reales ya persistidos (SpectrumSnapshot,
// GaoSourceItem) — el modelo solo redacta sobre hechos que le pasamos, nunca inventa cifras.
// sourceSummary guarda cuántas filas de cada fuente se usaron, para poder auditar el boletín.
model Briefing {
  id            String   @id @default(cuid())
  kind          String // 'diario' | 'ejecutivo'
  content       String
  sourceSummary Json
  generatedAt   DateTime @default(now())

  @@index([kind, generatedAt])
}

// Artículos ingeridos por RSS desde organizaciones independientes de monitoreo
// de conflicto armado (INDEPAZ, CERAC, PARES). Nunca contenido publicado
// directamente por un actor armado — solo terceros que reportan/analizan.
model GaoSourceItem {
  id              String   @id @default(cuid())
  source          String
  title           String
  link            String   @unique
  summary         String
  publishedAt     DateTime
  categories      String[]
  mentionedGroups String[]
  createdAt       DateTime @default(now())

  @@index([source])
  @@index([publishedAt])
}
