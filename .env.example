# Postgres (Vercel Storage → Create Database → Postgres, o cualquier Postgres).
# DATABASE_URL = conexión pooled (para la app en runtime).
# DIRECT_URL   = conexión directa/no-pooled (para prisma migrate / prisma db seed).
DATABASE_URL=
DIRECT_URL=

# Secreto para firmar las cookies de sesión (HMAC-SHA256).
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
