# Postgres (Vercel Storage → Create Database → Postgres, o cualquier Postgres).
# DATABASE_URL = conexión pooled (para la app en runtime).
# DIRECT_URL   = conexión directa/no-pooled (para prisma migrate / prisma db seed).
DATABASE_URL=
DIRECT_URL=

# Secreto para firmar las cookies de sesión (HMAC-SHA256).
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Protege /api/gao/ingest y /api/spectrum/snapshot (Vercel Cron envía
# Authorization: Bearer $CRON_SECRET automáticamente cuando la variable se llama exactamente CRON_SECRET).
CRON_SECRET=

# Clave de la API de Anthropic — usada por lib/ai/briefing.ts para redactar boletines/briefings
# a partir de datos reales ya persistidos. Se obtiene en https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
